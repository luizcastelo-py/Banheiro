<title>Controle de Banheiro da Sala</title>
<style>
body{font-family:Arial;background:#f4f6f8;margin:0;padding:20px}
.container{max-width:900px;margin:auto}
.card{background:white;padding:20px;border-radius:10px;box-shadow:0 4px 10px rgba(0,0,0,0.1);margin-bottom:20px}
button{padding:10px 15px;border:none;border-radius:6px;background:#2563eb;color:white;cursor:pointer}
button:disabled{background:#9ca3af}
ul{padding-left:20px}
</style>
</head>
