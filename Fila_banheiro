<div class="container">
<h1>Controle de Saída para o Banheiro</h1><div class="card" id="loginArea">
<h2>Entrar</h2>
<input id="nome" placeholder="Digite seu nome" />
<button onclick="login()">Entrar</button>
</div><div class="card" id="painel" style="display:none">
<h2 id="boasvindas"></h2>
<button onclick="pedirBanheiro()">Pedir para ir ao banheiro</button>
<button onclick="voltarSala()">Voltei para a sala</button>
</div><div class="card">
<h3>No banheiro (máx 2)</h3>
<ul id="banheiro"></ul>
</div><div class="card">
<h3>Fila de espera</h3>
<ul id="fila"></ul>
</div></div><script>
let usuario = null

function carregar(){
if(!localStorage.getItem('banheiro')) localStorage.setItem('banheiro',JSON.stringify([]))
if(!localStorage.getItem('fila')) localStorage.setItem('fila',JSON.stringify([]))
render()
}

function login(){
const nome=document.getElementById('nome').value.trim()
if(!nome) return alert('Digite um nome')
usuario=nome

document.getElementById('loginArea').style.display='none'
document.getElementById('painel').style.display='block'
document.getElementById('boasvindas').innerText='Olá, '+usuario
}

function pedirBanheiro(){
let banheiro=JSON.parse(localStorage.getItem('banheiro'))
let fila=JSON.parse(localStorage.getItem('fila'))

if(banheiro.includes(usuario) || fila.includes(usuario)) return

if(banheiro.length<2){
banheiro.push(usuario)
}else{
fila.push(usuario)
}

localStorage.setItem('banheiro',JSON.stringify(banheiro))
localStorage.setItem('fila',JSON.stringify(fila))
render()
}

